{
  "app": {
    "name": "SafeHeart",
    "version": "2.0.0",
    "description": "Emergencia para adultos mayores - SMS automático con ubicación GPS y pulsaciones cardíacas"
  },
  "defaultMessage": "EMERGENCIA! Adulto mayor necesita ayuda urgente. Hora: {TIME} | Pulsaciones: {BPM} bpm | Bateria: {BATTERY}% | Ubicacion: {LOCATION}",
  "smsConfig": {
    "maxLength": 160,
    "encoding": "UTF-8",
    "locationPlaceholder": "{LOCATION}",
    "timePlaceholder": "{TIME}",
    "batteryPlaceholder": "{BATTERY}",
    "bpmPlaceholder": "{BPM}"
  },
  "trackingConfig": {
    "intervalSeconds": 10,
    "durationMinutes": 3,
    "maxPoints": 50
  },
  "features": {
    "sms": true,
    "whatsapp": true,
    "email": true,
    "push": true,
    "gps": true,
    "tracking": true,
    "vibration": true,
    "sound": true,
    "heartRate": true
  },
  "alertChannels": {
    "sms": {
      "enabled": true,
      "description": "Mensaje de texto directo - funciona sin internet",
      "requiresInternet": false
    },
    "whatsapp": {
      "enabled": true,
      "description": "Mensaje via WhatsApp Web",
      "requiresInternet": true
    },
    "email": {
      "enabled": true,
      "description": "Correo electronico de emergencia",
      "requiresInternet": true
    },
    "push": {
      "enabled": true,
      "description": "Notificacion push en navegador",
      "requiresInternet": false
    }
  },
  "exampleContacts": [
    {
      "id": "1",
      "name": "Hijo/a",
      "phone": "+5491112345678",
      "email": "hijo@email.com",
      "relationship": "Familiar"
    },
    {
      "id": "2",
      "name": "Enfermero/a",
      "phone": "+5491187654321",
      "email": "enfermero@email.com",
      "relationship": "Cuidador"
    },
    {
      "id": "3",
      "name": "Médico",
      "phone": "+5491155551234",
      "relationship": "Médico"
    }
  ],
  "stats": {
    "activationTime": "3s",
    "trackingDuration": "3min",
    "trackingInterval": "10s",
    "method": "SMS + Monitor Cardíaco",
    "buttons": 1
  }
}